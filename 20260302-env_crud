def db_add_env_dict(env_data: EnvDict) -> EnvDictORM:
    db_logger.info(f"Adding new EnvDict entry: {env_data.alias}")
    try:
        with SessionLocal() as db:
            new_record = EnvDictORM(
                alias=env_data.alias,
                cluster_name_for_search=env_data.clusterNameForSearch,
                k8s_namespace=env_data.k8sNamespace,
                cluster_name=env_data.clusterName,
                env=env_data.env,
                region=env_data.region
            )
            db.add(new_record)
            db.commit()
            db.refresh(new_record)
            db_logger.info(f"Successfully added EnvDict entry with ID: {new_record.id}")
            return new_record
    except Exception as e:
        db_logger.error(f"Failed to add EnvDict: {e}")
        return None

def db_delete_env_dict(record_id: int) -> bool:
    db_logger.info(f"Deleting EnvDict entry with ID: {record_id}")
    try:
        with SessionLocal() as db:
            record = db.query(EnvDictORM).filter(EnvDictORM.id == record_id).first()
            if record:
                db.delete(record)
                db.commit()
                db_logger.info(f"Successfully deleted EnvDict entry with ID: {record_id}")
                return True
            else:
                db_logger.warning(f"EnvDict entry with ID {record_id} not found.")
                return False
    except Exception as e:
        db_logger.error(f"Failed to delete EnvDict: {e}")
        return False
