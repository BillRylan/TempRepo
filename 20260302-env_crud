from fastapi import APIRouter, HTTPException, Path
# from crud import db_add_env_dict, db_delete_env_dict
# from env_dict import EnvDict

router = APIRouter()

@router.post("/env-dict/", summary="新增环境配置")
def create_env_dict(env_data: EnvDict):
    new_record = db_add_env_dict(env_data)
    if new_record is None:
        raise HTTPException(status_code=500, detail="Database error occurred while creating record.")
    
    # 巧妙利用你写的 to_pydantic 并且带上新生成的 ID
    return {"message": "Success", "id": new_record.id, "data": new_record.to_pydantic()}

@router.delete("/env-dict/{record_id}", summary="删除环境配置")
def delete_env_dict(record_id: int = Path(..., description="要删除的记录 ID")):
    success = db_delete_env_dict(record_id)
    if not success:
        raise HTTPException(status_code=404, detail=f"Record with id {record_id} not found or deletion failed.")
    
    return {"message": "Successfully deleted", "id": record_id}



